{
  "id": "com.filiphammarstrom.teslacharging",
  "version": "1.0.0",
  "compatibility": ">=5.0.0",
  "brandColor": "#C8102E",
  "sdk": 3,
  "name": {
    "en": "Tesla Smart Charging",
    "sv": "Tesla Smart Charging"
  },
  "description": {
    "en": "Intelligent Tesla charging based on electricity prices",
    "sv": "Intelligent Tesla-laddning baserat på elpriser"
  },
  "category": "energy",
  "permissions": [
    "homey:manager:api",
    "homey:app:com.tesla.car"
  ],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "author": {
    "name": "Filip Hammarstrom",
    "email": "filip@filiphammarstrom.se"
  },
  "api": {
    "getStatus":        { "method": "GET",    "path": "/status",         "public": false },
    "getPrices":        { "method": "GET",    "path": "/prices",         "public": false },
    "setTrip":          { "method": "POST",   "path": "/trip",           "public": true  },
    "setTripGet":       { "method": "GET",    "path": "/trip/set",       "public": true  },
    "deleteTrip":       { "method": "DELETE", "path": "/trip",           "public": true  },
    "updateSettings":   { "method": "POST",   "path": "/settings",       "public": false },
    "postCalendarSync": { "method": "POST",   "path": "/calendar/sync",  "public": false }
  },
  "flow": {
    "triggers": [
      {
        "id": "cheap_charging_started",
        "title": {
          "en": "Cheap charging window started",
          "sv": "Billig laddningsstund börjar"
        }
      },
      {
        "id": "cheap_charging_ended",
        "title": {
          "en": "Cheap charging window ended",
          "sv": "Billig laddningsstund slutar"
        }
      },
      {
        "id": "emergency_charging_activated",
        "title": {
          "en": "Emergency charging activated (battery low)",
          "sv": "Nödladdning aktiverad (batteri lågt)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_cheap_electricity",
        "title": {
          "en": "It is !{{cheap|expensive}} electricity right now",
          "sv": "Det är !{{billig|dyr}} el just nu"
        }
      }
    ],
    "actions": [
      {
        "id": "set_next_trip",
        "title": {
          "en": "Set next trip",
          "sv": "Sätt nästa resa"
        },
        "titleFormatted": {
          "en": "Set next trip to [[departureTime]] and [[targetPercent]]%",
          "sv": "Sätt nästa resa till [[departureTime]] och [[targetPercent]]%"
        },
        "args": [
          {
            "name": "departureTime",
            "type": "text",
            "title": {
              "en": "Departure time (ISO 8601)",
              "sv": "Avgångstid (ISO 8601)"
            }
          },
          {
            "name": "targetPercent",
            "type": "number",
            "title": {
              "en": "Target battery %",
              "sv": "Mål-batteri %"
            },
            "min": 20,
            "max": 100
          }
        ]
      }
    ]
  }
}
